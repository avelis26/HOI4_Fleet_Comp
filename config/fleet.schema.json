{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "fleet.schema.json",
  "title": "Fleet",
  "type": "object",
  "required": ["theaters"],
  "additionalProperties": false,
  "properties": {
    "theaters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "fleets"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "fleets": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "display_column", "name", "task_forces"],
              "additionalProperties": false,
              "properties": {
                "id":             { "type": "string" },
                "display_column": { "type": "integer", "minimum": 1 },
                "name":           { "type": "string" },
                "task_forces": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "required": ["id", "role", "ships"],
                    "additionalProperties": false,
                    "properties": {
                      "id":   { "type": "string" },
                      "role": { "type": "string" },
                      "ships": {
                        "type": "object",
                        "additionalProperties": false,
                        "minProperties": 1,
                        "properties": {
                          "CV":   { "type": "integer", "minimum": 1 },
                          "CVL":  { "type": "integer", "minimum": 1 },
                          "BB":   { "type": "integer", "minimum": 1 },
                          "CA":   { "type": "integer", "minimum": 1 },
                          "CL":   { "type": "integer", "minimum": 1 },
                          "CLAA": { "type": "integer", "minimum": 1 },
                          "DD":   { "type": "integer", "minimum": 1 },
                          "DE":   { "type": "integer", "minimum": 1 },
                          "CM":   { "type": "integer", "minimum": 1 },
                          "SS":   { "type": "integer", "minimum": 1 }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}